<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro Instituição</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --FontFamily_1-FontFamily-FontFamily: 'Lexend', sans-serif;
      --FontFamily_1-FontSizes-FontSize_1: 36px;
      --FontFamily_1-FontSizes-FontSize_7: 16px;
      --FontFamily_1-FontSizes-FontSize_5: 20px;
      --placeholder: #A1A1A1;
      --500-primaria: #081998;
      --text-gray: #696868;
    }

    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #091E3A;
      background: -webkit-linear-gradient(to right, #2D9EE0, #2F80ED, #091E3A);
      background: linear-gradient(to right, #2D9EE0, #2F80ED, #091E3A);
      overflow: hidden;
      font-family: var(--FontFamily_1-FontFamily-FontFamily);
    }

    /* MOCKUP IPHONE 16 CORRETO */
    .smartphone-container {
      width: 288px;
      height: 608px;
      background: #000000;
      border-radius: 40px;
      padding: 6px;
      box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 0 4px rgba(255,255,255,0.2);
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* DYNAMIC ISLAND REAL E FLUTUANTE */
    .smartphone-notch {
      position: absolute;
      top: 11px;
      left: 50%;
      transform: translateX(-50%);
      width: 82px;
      height: 24px;
      background: #000000;
      border-radius: 20px;
      z-index: 10;
      box-shadow: inset 0 0 2px rgba(255,255,255,0.1);
    }

    .phone-screen {
      width: 100%;
      height: 100%;
      background: #FFF;
      overflow: hidden;
      position: relative;
      border-radius: 34px;
    }

    /* ESCALA DO CONTEÚDO FIGMA */
    .figma-content {
      position: absolute;
      width: 393px;
      height: 852px;
      top: 0;
      left: 0;
      transform: scale(0.712);
      transform-origin: top left;
      box-sizing: border-box;
      padding: 24px 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .top-bar {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 10px;
      margin-bottom: 5px;
    }

    .btn-back {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 62px;
      height: 59px;
      filter: drop-shadow(0px 4px 4px rgba(0, 0, 0, 0.25));
      z-index: 5;
    }

    .step-indicator {
      color: var(--text-gray);
      font-size: var(--FontFamily_1-FontSizes-FontSize_7);
      font-weight: 400;
    }

    .brand-logo {
      width: 121px;
      height: 121px;
      border-radius: 20px;
      object-fit: cover;
      margin-top: -10px;
    }

    .header-text {
      text-align: center;
      margin-top: 15px;
      margin-bottom: 20px;
    }

    .main-title {
      font-size: var(--FontFamily_1-FontSizes-FontSize_1);
      font-weight: 400;
      color: #000;
      margin: 0 0 8px 0;
    }

    .subtitle {
      font-size: var(--FontFamily_1-FontSizes-FontSize_7);
      font-weight: 400;
      color: #000;
      width: 281px;
      margin: 0 auto;
      line-height: 1.3;
    }

    .form-container {
      width: 335px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .input-group label {
      font-size: var(--FontFamily_1-FontSizes-FontSize_5);
      color: #000;
      font-weight: 400;
      text-align: left;
    }

    .input-field {
      width: 100%;
      height: 50px;
      border-radius: 20px;
      background: #F1F1F1;
      border: none;
      box-sizing: border-box;
      padding: 0 20px;
      font-family: var(--FontFamily_1-FontFamily-FontFamily);
      font-size: var(--FontFamily_1-FontSizes-FontSize_7);
      color: #000;
      outline: none;
    }

    .input-field::placeholder {
      color: var(--placeholder);
    }

    .upload-field {
      width: 100%;
      height: 66px;
      border-radius: 20px;
      background: #F1F1F1;
      box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.10);
      display: flex;
      align-items: center;
      padding: 0 16px;
      box-sizing: border-box;
      cursor: pointer;
      gap: 12px;
      border: none;
    }

    .upload-text {
      color: var(--text-gray);
      font-size: var(--FontFamily_1-FontSizes-FontSize_5);
      font-family: var(--FontFamily_1-FontFamily-FontFamily);
    }

    .btn-submit {
      width: 148px;
      height: 56px;
      border-radius: 20px;
      background: var(--500-primaria);
      border: none;
      color: #FFF;
      font-family: var(--FontFamily_1-FontFamily-FontFamily);
      font-size: var(--FontFamily_1-FontSizes-FontSize_5);
      font-weight: 400;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
      margin-top: 15px;
    }

    .btn-submit:hover {
      opacity: 0.9;
    }
  </style>
</head>
<body>

  <div class="smartphone-container">
    <div class="smartphone-notch"></div>
    
    <div class="phone-screen">
      <div class="figma-content">
        
        <div class="top-bar">
          <button class="btn-back" onclick="window.history.back()" aria-label="Voltar">
            <svg width="62" height="59" viewBox="0 0 62 59" fill="none" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="31" cy="29.5" rx="31" ry="29.5" fill="white"/>
              <path d="M21.6 29.5L29.3 37.2C29.7 37.6 29.7 38.2 29.3 38.6C28.9 39 28.3 39 27.9 38.6L18.7 29.4C18.5 29.2 18.5 28.8 18.7 28.6L27.9 19.4C28.3 19 28.9 19 29.3 19.4C29.7 19.8 29.7 20.4 29.3 20.8L21.6 28.5H39.3C39.9 28.5 40.3 28.9 40.3 29.5C40.3 30.1 39.9 30.5 39.3 30.5H21.6Z" fill="black"/>
            </svg>
          </button>
          <div class="step-indicator">1/2</div>
        </div>

        <img class="brand-logo" src="https://api.builder.io/api/v1/image/assets/TEMP/0172e7dd37ba8858accae72af0a5f7013aafb5c9?width=242" alt="Logo" />

        <header class="header-text">
          <h1 class="main-title">Bem-vindo!</h1>
          <p class="subtitle">Complete as informações para avançar com o cadastro.</p>
        </header>

        <form class="form-container" onsubmit="event.preventDefault();">
          
          <div class="input-group">
            <label for="razao-social">Razão Social:</label>
            <input type="text" id="razao-social" class="input-field" placeholder="Ex: Centro Educacional São José LTDA." required>
          </div>
          
          <div class="input-group">
            <label for="cnpj">CNPJ:</label>
            <input type="text" id="cnpj" class="input-field" placeholder="Ex: 60.311.238/0001-98" required>
          </div>
          
          <div class="input-group">
            <label for="cnae">CNAE:</label>
            <input type="text" id="cnae" class="input-field" placeholder="Ex: 85.13-9-00 - Ensino fundamental" required>
          </div>
          
          <div class="input-group">
            <label>Declaração institucional:</label>
            <label class="upload-field" role="button">
              <input type="file" style="display: none;">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 26.6667H25V16.6667H31.6666L20 5L8.33331 16.6667H15V26.6667ZM8.33331 30H31.6666V33.3333H8.33331V30Z" fill="#696868"/>
              </svg>
              <span class="upload-text">Anexar documento</span>
            </label>
          </div>

          <div style="display: flex; justify-content: center; width: 100%;">
            <button type="submit" class="btn-submit">Avançar</button>
          </div>

        </form>

      </div>
    </div>
  </div>

</body>
</html>
